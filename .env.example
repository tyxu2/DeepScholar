# Required: at least one LLM provider key
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=

# Optional: paper search / GitHub tools
SEMANTIC_SCHOLAR_API_KEY=
GITHUB_TOKEN=

# Routing (optional overrides)
DEEPSCHOLAR_MODEL_PLAN=gpt-4o
DEEPSCHOLAR_MODEL_WRITE=gpt-4o
DEEPSCHOLAR_MODEL_CRITIC=gpt-4o-mini

# Optional: LangSmith observability
# Set LANGSMITH_API_KEY to enable tracing (Thought / Action / Observation
# spans, model calls, sub-researcher fan-out). Leave empty to disable.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=deepscholar
# LANGSMITH_ENDPOINT=          # for self-hosted LangSmith
# LANGSMITH_TRACING=false      # force-disable even if a key is set
